# AcademyJournal — deployment environment (server-side).
# Copy to .env and fill in real secrets. NEVER commit the real .env.
# The real .env is git-ignored and lives only on the server.

# ── Django ───────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-string
# Host/IP (and later the domain) that may serve the app:
ALLOWED_HOSTS=173.249.29.176,localhost,127.0.0.1
# Origins allowed to send unsafe (POST/PUT) requests — admin login, etc.
CSRF_TRUSTED_ORIGINS=http://173.249.29.176:8080
# CORS is not needed for the same-origin SPA, but kept for local dev:
CORS_ALLOWED_ORIGINS=http://173.249.29.176:8080,http://localhost:5173

# ── Database (dockerised PostgreSQL 16) ──────────────────────────────────
POSTGRES_DB=academyjournal
POSTGRES_USER=academy_app
POSTGRES_PASSWORD=change-me
# Django reads this; host "db" is the compose service name.
DATABASE_URL=postgres://academy_app:change-me@db:5432/academyjournal

# ── Optional features (require a public HTTPS domain — enable later) ──────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=admin@academyjournal.uz
